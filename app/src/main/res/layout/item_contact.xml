<?xml version="1.0" encoding="utf-8"?>
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvContactAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#FFB3B3"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvContactName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#3D4A7A"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvContactRelation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAB4D4"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvContactPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8A9EE0"
                android:textSize="11sp"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnCall"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="📞"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#F0F4FF"/>

    </LinearLayout>